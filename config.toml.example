# Host config for the per-host Manager — copy to ~/.loopworker/config.toml.
# One Manager per host serves EVERY project in the shared backlog whose
# worker_manager is this host's, cloning each on demand. PATCH_PAT stays in .env.

worker_manager = "miquon"          # this host's id (match the projects table's Worker manager)
clones_dir     = "~/Dev/loopworker-clones"
max_slots      = 4                  # host-wide RAM budget, in weighted slot-cost units
                                     # (a project's "weight" column, default 1, is its
                                     # relative cost per slot, see the projects table)
# max_concurrent_workers = 3       # host-wide cap on claudes RUNNING at once (defaults to
                                   # max_slots). Set lower to keep lots of cold capacity but
                                   # few concurrent auths — concurrent claudes on one account
                                   # race the shared OAuth refresh and can trip session
                                   # revocation. Starts stagger ~reconcile_interval apart.
# base_port    = 54400             # first slot's stack port (projects get 1000-apart bands)
# port_step    = 100              # port gap between a project's own slots
# notify_command receives an alert message on stdin (worker auth failure, a slot
# marked BROKEN) - any CLI push tool works, e.g. Pushover via curl:
# notify_command = "curl -s -F token=$PUSHOVER_TOKEN -F user=$PUSHOVER_USER -F message=@- https://api.pushover.net/1/messages.json"

[backlog]
api_base   = "https://api.patch.d.nevyn.dev"
anon_key   = "<deployment public anon key>"   # PostgREST/Kong apikey header; grants nothing alone
# app_base and roadmap_page_id let the dashboard turn ~NNN card refs into links to Patch.
# app_base is the APP origin (not api_base); roadmap_page_id is the roadmap table's
# patch_items id. Leave unset to keep ~NNN as plain text.
# app_base        = "https://patch.d.nevyn.dev"
# roadmap_page_id = "ea3c65fb-9038-4dcb-8223-34dd395b2af8"
# brief_page = "https://patch.d.nevyn.dev/app/b5b7a703-63eb-4159-8fc9-e2b4963586f5"  # shared loop page
# roadmap_table  = "roadmap"
# workers_table  = "loop_workers"
# projects_table = "projects"
