# The Manager talks to Patch over PostgREST (NOT the MCP), so it needs a Supabase
# service_role key for the target Patch instance. This bypasses RLS — it is required
# for the Manager to read/write the roadmap, and must never be committed.
PATCH_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# The Workers' `claude` CLI must be logged in on this host once (interactive claude
# inherits that auth — there is no per-Worker login). Nothing to set here for that.
